msgstr ""

#: src/kernel/linux-compatibility/kernel-parameters.md:62
msgid "Override ACPI's indication of whether a PS/2 (i8042) controller exists."
msgstr ""

#: src/kernel/linux-compatibility/kernel-parameters.md:65
msgid ""
