#: src/distro/popular-applications/nix-and-nixos-tools/index.md:14
msgid "`nix-build`"
msgstr ""

#: src/distro/popular-applications/nix-and-nixos-tools/index.md:16
msgid ""
"`nix-build` builds Nix derivations and produces outputs in the Nix store. It "
"is the preferred way to build software reproducibly."
msgstr ""

#: src/distro/popular-applications/nix-and-nixos-tools/index.md:20
msgid "# Step 1: Create a clean workspace\n"
msgstr ""

#: src/distro/popular-applications/nix-and-nixos-tools/index.md:22
msgid "# Step 2: Write a C program\n"
msgstr ""

#: src/distro/popular-applications/nix-and-nixos-tools/index.md:24
msgid ""
"<<'EOF'\n"
"#include <stdio.h>\n"
"\n"
"int main(void) {\n"
"    puts(\"Hello, World!\");\n"
"    return 0;\n"
"}\n"
"EOF\n"
"\n"
"# Step 3: Write a default.nix\n"
"cat > default.nix <<'EOF'\n"
"{ pkgs ? import <nixpkgs> {} }:\n"
"\n"
"pkgs.stdenv.mkDerivation {\n"
"  pname = \"hello-c\";\n"
"  version = \"0.1.0\";\n"
"  src = ./.;\n"
"\n"
"  dontConfigure = true;\n"
"\n"
"  buildPhase = ''\n"
"    cc hello.c -o hello\n"
"  '';\n"
"\n"
"  installPhase = ''\n"
"    mkdir -p $out/bin\n"
"    install -m755 hello $out/bin/hello\n"
"  '';\n"
"}\n"
"EOF\n"
"\n"
"# Step 4: Build and run\n"
"nix-build\n"
"./result/bin/hello\n"
msgstr ""

